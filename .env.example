# Database
POSTGRES_PASSWORD=poke_secret

# Scraper
SCRAPER_MONTHS_LOOKBACK=3
SCRAPER_WORKERS=3
SCRAPER_DELAY_SECONDS=2.0
ALLOW_MANUAL_SCRAPE=false

# pokemontcg.io API key (optional; free registration increases rate limits)
POKEMONTCG_API_KEY=

# Production
# DATABASE_URL=postgresql+asyncpg://...
# ALLOWED_ORIGINS=https://your-frontend.railway.app
# NEXT_PUBLIC_API_URL=https://your-backend.railway.app
